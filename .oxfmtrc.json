{
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "all",
	"printWidth": 120,
	"semi": false,
	"svelte": true,
	"sortPackageJson": true,
	"ignorePatterns": [
		".DS_Store",
		"node_modules",
		"/build",
		"/.svelte-kit",
		"/package",
		".env",
		".env.*",
		"!.env.example",
		"pnpm-lock.yaml",
		"package-lock.json",
		"yarn.lock"
	]
}
