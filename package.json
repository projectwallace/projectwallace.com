{
	"name": "project-wallace-com",
	"description": "Svelte Kit project for projectwallace.com",
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "playwright test",
		"test:unit": "vitest --exclude **/*.spec.ts",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "svelte-kit sync && oxlint --config oxlintrc.json",
		"stylelint": "stylelint \"src/**/*.{css,svelte}\" --ignore-path .gitignore --report-needless-disables --report-descriptionless-disables --report-unscoped-disables",
		"css-coverage": "css-coverage ./css-coverage --min-coverage=.9  --min-file-coverage=.66 --show-uncovered=all"
	},
	"dependencies": {
		"@melt-ui/pp": "^0.3.2",
		"@melt-ui/svelte": "^0.86.6",
		"@oddbird/popover-polyfill": "^0.6.1",
		"@projectwallace/css-analyzer": "^9.6.0",
		"@projectwallace/css-code-coverage": "^0.10.0",
		"@projectwallace/css-code-quality": "^3.1.1",
		"@projectwallace/css-design-tokens": "^0.11.2",
		"@projectwallace/css-layer-tree": "^2.1.2",
		"@projectwallace/css-parser": "^0.13.11",
		"@projectwallace/format-css": "^3.0.0",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"color-sorter": "^7.0.2",
		"css-time-sort": "^3.0.0",
		"diff": "^8.0.2",
		"linkedom": "^0.18.12",
		"mdsvex": "^0.12.7",
		"paneforge": "^1.0.2",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"runed": "^0.37.1",
		"svelte": "^5.55.0",
		"typescript": "^5.9.3",
		"vite": "8.0.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@projectwallace/stylelint-plugin": "^0.1.12",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@types/node": "^24.10.0",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.0",
		"postcss-html": "^1.8.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"stylelint": "~17.6.0",
		"stylelint-config-standard": "~40.0.0",
		"stylelint-value-no-unknown-custom-properties": "^6.1.1",
		"svelte-check": "^4.4.5",
		"vitest": "^4.1.0"
	},
	"overrides": {
		"@projectwallace/css-analyzer": "$@projectwallace/css-analyzer",
		"@projectwallace/css-parser": "$@projectwallace/css-parser",
		"@projectwallace/format-css": "$@projectwallace/format-css",
		"color-sorter": "$color-sorter",
		"runed": "$runed",
		"sharp": "0.34.3",
		"vite": "$vite"
	}
}
