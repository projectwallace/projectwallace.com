{
	"name": "project-wallace-com",
	"version": "0.0.1",
	"private": true,
	"description": "Svelte Kit project for projectwallace.com",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "playwright test",
		"test:unit": "vitest --exclude **/*.spec.ts",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "svelte-kit sync && oxlint --config oxlintrc.json",
		"stylelint": "stylelint \"src/**/*.{css,svelte}\" --ignore-path .gitignore --report-needless-disables --report-descriptionless-disables --report-unscoped-disables",
		"stylelint-full": "vite build >/dev/null 2>&1 && find .svelte-kit/output/server/_app/immutable/assets -name '*.css' -exec cat {} + > .svelte-kit/holistic.css 2>/dev/null && format-css .svelte-kit/holistic.css > .svelte-kit/holistic-formatted.css 2>/dev/null && stylelint .svelte-kit/holistic-formatted.css --config=.stylelintrc.mjs",
		"css-coverage": "css-coverage ./css-coverage --min-coverage=.9  --min-file-coverage=.66 --show-uncovered=all"
	},
	"dependencies": {
		"@melt-ui/pp": "^0.3.2",
		"@melt-ui/svelte": "^0.86.6",
		"@oddbird/popover-polyfill": "^0.6.1",
		"@projectwallace/css-analyzer": "^9.8.2",
		"@projectwallace/css-code-coverage": "^1.0.2",
		"@projectwallace/css-code-quality": "^3.1.3",
		"@projectwallace/css-design-tokens": "^0.11.6",
		"@projectwallace/css-layer-tree": "^2.1.4",
		"@projectwallace/css-parser": "~0.16.0",
		"@projectwallace/css-time-sort": "^3.1.0",
		"@projectwallace/format-css": "^3.1.3",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"color-sorter": "^8.0.0",
		"diff": "^9.0.0",
		"github-slugger": "^2.0.0",
		"linkedom": "^0.18.12",
		"mdsvex": "^0.12.7",
		"paneforge": "^1.0.2",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"runed": "^0.37.1",
		"svelte": "^5.55.8",
		"typescript": "^6.0.3",
		"vite": "8.0.13"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@projectwallace/stylelint-plugin": "^0.4.6",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@types/node": "^25.9.1",
		"oxfmt": "0.51.0",
		"oxlint": "^1.66.0",
		"oxlint-tsgolint": "^0.23.0",
		"postcss-html": "^1.8.1",
		"stylelint": "~17.11.1",
		"stylelint-config-standard": "~40.0.0",
		"svelte-check": "^4.4.8",
		"vitest": "^4.1.6"
	},
	"engines": {
		"node": ">=24",
		"pnpm": ">=10"
	},
	"packageManager": "pnpm@10.30.3"
}
